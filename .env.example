# Release Copilot — local configuration template.
# Copy to `.env` (gitignored) and fill in YOUR values. In-cluster these same keys are
# supplied by the Helm ConfigMap (helm/release-copilot/values.yaml -> config), which
# takes precedence over this file. Nothing here is hardcoded in the source.

# --- Repos (required) ---
# BUILD_REPO : code + image catalog (image-workflows.json) + builds/tags + RLFT controls.
# DEPLOY_REPO: SIT/UAT/PRD protected branches + configs/images.json edited by the PR chain.
BUILD_REPO=org/build-repo
DEPLOY_REPO=org/deploy-repo

# --- Vertex AI Gen AI (Gemini) ---
# Project is auto-detected from gcloud if unset. Do NOT hardcode secrets here.
# GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
# GEMINI_MODEL=gemini-2.5-flash
# Connect using your installed gcloud + ADC:  gcloud auth application-default login
# Budget protection is built-in; the agent asks before exceeding the limit.

# --- GitHub auth (PyGithub) ---
# If GH_TOKEN/GITHUB_TOKEN are unset, the app falls back to your `gh` CLI login
# (gh auth token). To pin an explicit token instead:
# GH_TOKEN=ghp_xxx

# --- Optional overrides (defaults shown; safe to omit) ---
# DEFAULT_WORKFLOW=image-tag-step-report.yml
# ON_MERGE_WORKFLOW=on-merge-deploy.yml
# SIT_BRANCH=SIT
# UAT_BRANCH=UAT
# PRD_BRANCH=PRD
# ENV_CONFIG_PATH=configs/images.json
# CHANGE_REQUEST_PATH=change-request.json
# PRD_CUTOFF_HOUR_UTC=16
# PRD_LEAD_TIME_DAYS=1
# CONTROL_PREFIXES=RLFT,RFTL
# PRD_REQUIRE_CONTROLS=true
# RELEASE_CORS_ORIGINS=https://app.example.com,https://admin.example.com
# LANGSMITH_API_KEY=...
# LANGSMITH_PROJECT=release-copilot
