# Copy to .env and fill (all of these are optional — sensible defaults + gcloud/gh auto-detect apply)

# --- Vertex AI Gen AI (Gemini) ---
# Project is auto-detected from gcloud if not set. Do NOT hardcode secrets here.
# GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
# Model id — gemini-2.0-flash was retired; default is gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# Connect using your already installed gcloud + ADC:
#   gcloud auth application-default login

# Budget protection is built-in (£10 hard limit). The agent asks before exceeding.

# --- GitHub auth (PyGithub) ---
# If GH_TOKEN/GITHUB_TOKEN are unset, the app falls back to your `gh` CLI login
# (gh auth token). To pin an explicit token instead:
# GH_TOKEN=ghp_xxx

# --- Repos ---
# Manifest / source repo (where the manifest JSON is updated and the workflow is dispatched)
RELEASE_AGENT_TARGET_REPO=phaniuk111/devops

# Deployment repo (where the dispatched workflow opens the PR with the prod config)
DEPLOY_REPO=phaniuk111/deployment-repo

# Default workflow to dispatch on promote
DEFAULT_WORKFLOW=image-tag-step-report.yml

# CORS for the FastAPI app — comma-separated OR a JSON array
# RELEASE_CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Optional: LangSmith
# LANGSMITH_API_KEY=...
# LANGSMITH_PROJECT=release-copilot-pov
